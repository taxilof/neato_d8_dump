				compatible = "fsl,imx8mn-fec\0fsl,imx8mq-fec\0fsl,imx6sx-fec";
				reg = <0x30be0000 0x10000>;
				interrupts = <0x00 0x76 0x04 0x00 0x77 0x04 0x00 0x78 0x04>;
				clocks = <0x02 0x8b 0x02 0x8b 0x02 0x63 0x02 0x62 0x02 0x64>;
				clock-names = "ipg\0ahb\0ptp\0enet_clk_ref\0enet_out";
				assigned-clocks = <0x02 0x4c 0x02 0x63 0x02 0x62 0x02 0x63>;
				assigned-clock-parents = <0x02 0x36 0x02 0x3a 0x02 0x3b>;
				assigned-clock-rates = <0x00 0x00 0x7735940 0x5f5e100>;
				fsl,num-tx-queues = <0x03>;
				fsl,num-rx-queues = <0x03>;
				stop-mode = <0x2d 0x10 0x03>;
				fsl,wakeup_irq = <0x02>;
				status = "okay";
				pinctrl-names = "default";
				pinctrl-0 = <0x2e>;
				phy-mode = "rgmii-id";
				phy-handle = <0x2f>;
				fsl,magic-packet;

				mdio {
					#address-cells = <0x01>;
					#size-cells = <0x00>;

					ethernet-phy@0 {
						compatible = "ethernet-phy-ieee802.3-c22";
						reg = <0x00>;
						at803x,led-act-blind-workaround;
						at803x,eee-disabled;
						at803x,vddio-1p8v;
						phandle = <0x2f>;
					};
				};
			};
		};

		bus@32c00000 {
			compatible = "fsl,aips-bus\0simple-bus";
			reg = <0x32c00000 0x400000>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			ranges;

			lcd-controller@32e00000 {
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				compatible = "fsl,imx8mn-lcdif";
				reg = <0x32e00000 0x10000>;
				clocks = <0x02 0xba 0x02 0xb8 0x02 0xb9>;
				clock-names = "pix\0disp-axi\0disp-apb";
				assigned-clocks = <0x02 0x5c 0x02 0x4e 0x02 0x4f>;
				assigned-clock-parents = <0x02 0x28 0x02 0x41 0x02 0x38>;
				assigned-clock-rates = <0x2367b880 0x1dcd6500 0xbebc200>;
				interrupts = <0x00 0x05 0x04>;
				resets = <0x30>;
				power-domains = <0x08>;
				status = "disabled";

				port@0 {
					reg = <0x00>;
					phandle = <0x35>;

					endpoint {
						remote-endpoint = <0x31>;
						phandle = <0x34>;
					};
				};
			};

			dsi_controller@32e10000 {
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				compatible = "fsl,imx8mn-mipi-dsim";
				reg = <0x32e10000 0x400>;
				clocks = <0x02 0x7d 0x02 0x7e>;
				clock-names = "cfg\0pll-ref";
				assigned-clocks = <0x02 0x7d 0x02 0x7e>;
				assigned-clock-parents = <0x02 0x36 0x02 0x28>;
				assigned-clock-rates = <0xfdad680 0x2367b880>;
				interrupts = <0x00 0x12 0x04>;
				resets = <0x32>;
				power-domains = <0x33>;
				status = "disabled";

				port@0 {

					endpoint {
						remote-endpoint = <0x34>;
						phandle = <0x31>;
					};
				};
			};

			display-subsystem {
				compatible = "fsl,imx-display-subsystem";
				ports = <0x35>;
			};

			usb@32e40000 {
				compatible = "fsl,imx8mn-usb\0fsl,imx7d-usb\0fsl,imx27-usb";
				reg = <0x32e40000 0x200>;
				interrupts = <0x00 0x28 0x04>;
				clocks = <0x02 0xad>;
				clock-names = "usb1_ctrl_root_clk";
				assigned-clocks = <0x02 0x50 0x02 0x71>;
				assigned-clock-parents = <0x02 0x40 0x02 0x32>;
				fsl,usbphy = <0x36>;
				fsl,usbmisc = <0x37 0x00>;
				power-domains = <0x38>;
				status = "okay";
				extcon = <0x39>;
			};

			usbmisc@32e40200 {
				compatible = "fsl,imx8mn-usbmisc\0fsl,imx7d-usbmisc";
				#index-cells = <0x01>;
				reg = <0x32e40200 0x200>;
				phandle = <0x37>;
			};

			usb@32e50000 {
				compatible = "fsl,imx8mn-usb\0fsl,imx7d-usb\0fsl,imx27-usb";
				reg = <0x32e50000 0x200>;
				interrupts = <0x00 0x29 0x04>;
				clocks = <0x02 0xad>;
				clock-names = "usb1_ctrl_root_clk";
				assigned-clocks = <0x02 0x50 0x02 0x71>;
				assigned-clock-parents = <0x02 0x40 0x02 0x32>;
				fsl,usbphy = <0x3a>;
				fsl,usbmisc = <0x3b 0x00>;
				status = "okay";
				extcon = <0x3c>;
			};

			usbmisc@32e50200 {
				compatible = "fsl,imx8mn-usbmisc\0fsl,imx7d-usbmisc";
				#index-cells = <0x01>;
				reg = <0x32e50200 0x200>;
				phandle = <0x3b>;
			};
		};

		dma-controller@33000000 {
			compatible = "fsl,imx7d-dma-apbh\0fsl,imx28-dma-apbh";
			reg = <0x33000000 0x2000>;
			interrupts = <0x00 0x0c 0x04 0x00 0x0c 0x04 0x00 0x0c 0x04 0x00 0x0c 0x04>;
			interrupt-names = "gpmi0\0gpmi1\0gpmi2\0gpmi3";
			#dma-cells = <0x01>;
			dma-channels = <0x04>;
			clocks = <0x02 0xc0>;
			phandle = <0x3d>;
		};

		nand-controller@33002000 {
			compatible = "fsl,imx8mn-gpmi-nand\0fsl,imx7d-gpmi-nand";
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			reg = <0x33002000 0x2000 0x33004000 0x4000>;
			reg-names = "gpmi-nand\0bch";
			interrupts = <0x00 0x0e 0x04>;
			interrupt-names = "bch";
			clocks = <0x02 0x9c 0x02 0xc0>;
			clock-names = "gpmi_io\0gpmi_bch_apb";
			dmas = <0x3d 0x00>;
			dma-names = "rx-tx";
			status = "disabled";
		};

		interrupt-controller@38800000 {
			compatible = "arm,gic-v3";
			reg = <0x38800000 0x10000 0x38880000 0xc0000>;
			#interrupt-cells = <0x03>;
			interrupt-controller;
			interrupts = <0x01 0x09 0x04>;
			phandle = <0x01>;
		};
	};

	usbphynop1 {
		compatible = "usb-nop-xceiv";
		clocks = <0x02 0x72>;
		assigned-clocks = <0x02 0x72>;
		assigned-clock-parents = <0x02 0x32>;
		clock-names = "main_clk";
		phandle = <0x36>;
	};

	usbphynop2 {
		compatible = "usb-nop-xceiv";
		clocks = <0x02 0x72>;
		assigned-clocks = <0x02 0x72>;
		assigned-clock-parents = <0x02 0x32>;
		clock-names = "main_clk";
		phandle = <0x3a>;
	};

	dispmix-reset {
		compatible = "simple-bus";
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		dispmix-sft-rstn@32e28000 {
			compatible = "fsl,imx8mn-dispmix-sft-rstn";
			reg = <0x00 0x32e28000 0x00 0x04>;
			clocks = <0x02 0xb9>;
			clock-names = "disp_apb_root_clk";
			active_low;
			power-domains = <0x08>;
			#reset-cells = <0x01>;
			phandle = <0x3e>;
		};

		dispmix-clk-en@32e28004 {
			compatible = "fsl,imx8mn-dispmix-clk-en";
			reg = <0x00 0x32e28004 0x00 0x04>;
			clocks = <0x02 0xb9>;
			clock-names = "disp_apb_root_clk";
			power-domains = <0x08>;
			#reset-cells = <0x01>;
			phandle = <0x3f>;
		};

		dispmix-mipi-rst@32e28008 {
			compatible = "fsl,imx8mn-dispmix-mipi-rst";
			reg = <0x00 0x32e28008 0x00 0x04>;
			clocks = <0x02 0xb9>;
			clock-names = "disp_apb_root_clk";
			active_low;
			power-domains = <0x08>;
			#reset-cells = <0x01>;
			phandle = <0x40>;
		};
	};

	lcdif-resets {
		#address-cells = <0x01>;
		#size-cells = <0x00>;
		#reset-cells = <0x00>;
		phandle = <0x30>;

		lcdif-soft-resetn {
			compatible = "lcdif,soft-resetn";
			resets = <0x3e 0x05 0x3e 0x04>;
		};

		lcdif-clk-enable {
			compatible = "lcdif,clk-enable";
			resets = <0x3f 0x05 0x3f 0x04>;
		};
	};

	mipi-dsi-resets {
		#address-cells = <0x01>;
		#size-cells = <0x00>;
		#reset-cells = <0x00>;
		phandle = <0x32>;

		dsi-soft-resetn {
			compatible = "dsi,soft-resetn";
			resets = <0x3e 0x01 0x3e 0x00>;
		};

		dsi-clk-enable {
			compatible = "dsi,clk-enable";
			resets = <0x3f 0x01 0x3f 0x00>;
		};

		dsi-mipi-reset {
			compatible = "dsi,mipi-reset";
			resets = <0x40 0x01>;
		};
	};

	chosen {
		bootargs = "console=ttymxc1,115200 earlycon=ec_imx6q,0x30890000,115200";
		stdout-path = "/soc@0/bus@30800000/serial@30890000";
	};

	regulator-usdhc2 {
		compatible = "regulator-fixed";
		pinctrl-names = "default";
		pinctrl-0 = <0x41>;
		regulator-name = "VSD_3V3";
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		gpio = <0x42 0x13 0x00>;
		enable-active-high;
		startup-delay-us = <0x64>;
		off-on-delay-us = <0x2ee0>;
		phandle = <0x28>;
	};
};
